{
  "name": "stainless-logic-sidecar",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "rm -rf .next && next dev",
    "build": "rm -rf .next-build && NEXT_DIST_DIR=.next-build next build",
    "start": "NEXT_DIST_DIR=.next-build next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "seed": "node scripts/seed.mjs"
  },
  "dependencies": {
    "imapflow": "^1.2.10",
    "mailparser": "^3.9.3",
    "next": "15.1.11",
    "nodemailer": "^6.9.16",
    "openai": "4.83.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "xlsx": "^0.18.5",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/node": "22.10.5",
    "@types/nodemailer": "^6.4.16",
    "@types/react": "19.0.5",
    "@types/react-dom": "19.0.2",
    "autoprefixer": "10.4.20",
    "eslint": "9.17.0",
    "eslint-config-next": "15.1.6",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.3"
  }
}

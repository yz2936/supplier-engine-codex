OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat
LLM_PROVIDER=openai

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_app_password
SMTP_FROM=your_email@example.com

INBOUND_EMAIL_SECRET=
INBOUND_ROUTE_ADDRESS=your_email@example.com

# Optional if different from SMTP account. If omitted, app falls back to SMTP_USER/SMTP_PASS.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=your_email@example.com
IMAP_PASS=your_email_app_password

INBOUND_LLM_FILTER=true
INBOUND_FILTER_MODEL=gpt-4o-mini

RAW_MATERIAL_API_URL_TEMPLATE=
RAW_MATERIAL_API_KEY=
RAW_MATERIAL_API_KEY_HEADER=x-api-key

# Optional: local/dev file path override for app data.
# On Vercel, default is /tmp/app-data.json if DATA_PATH is not set.
DATA_PATH=

# Persistent database (recommended for Vercel production)
DATABASE_URL=
# Optional: set to false only for local non-SSL postgres
DATABASE_SSL=
# Optional logical namespace for app-state row key
APP_STATE_KEY=main

# Session signing secret (required in production)
SESSION_SECRET=replace_with_a_long_random_secret
